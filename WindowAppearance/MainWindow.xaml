<Window x:Class="WindowAppearance.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WindowAppearance"
        Title="Curse" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Верхняя панель с кнопкой и информацией -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Загрузить изображение" 
                    Command="{Binding LoadImageCommand}"
                    Padding="10,5"
                    Margin="0,0,10,0"/>
            <TextBlock Text="{Binding ImageInfo}" 
                       VerticalAlignment="Center"
                       FontSize="12"/>
        </StackPanel>

        <!-- Область для исходного изображения -->
        <Border Grid.Row="1" Grid.Column="0" 
                BorderBrush="Gray" BorderThickness="1" 
                Margin="0,0,5,0">
            <Grid>
                <TextBlock Text="Исходное изображение" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Top" 
                           Margin="5"
                           Background="White"
                           Padding="2"/>
                <Image Source="{Binding OriginalImage}" 
                       Stretch="Uniform"
                       Margin="5"/>
            </Grid>
        </Border>

        <!-- Разделитель -->
        <TextBlock Grid.Row="1" Grid.Column="1" 
                   Text="→" 
                   VerticalAlignment="Center" 
                   HorizontalAlignment="Center"
                   FontSize="24"
                   FontWeight="Bold"/>

        <!-- Область для сегментированного изображения -->
        <Border Grid.Row="1" Grid.Column="2" 
                BorderBrush="Gray" BorderThickness="1" 
                Margin="5,0,0,0">
            <Grid>
                <TextBlock Text="Сегментированное изображение" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Top" 
                           Margin="5"
                           Background="White"
                           Padding="2"/>
                <Image Source="{Binding SegmentedImage}" 
                       Stretch="Uniform"
                       Margin="5"/>
            </Grid>
        </Border>

        <!-- Нижняя панель управления -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="3" 
                    Orientation="Horizontal" 
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center">
            <TextBlock Text="Количество кластеров: " VerticalAlignment="Center"/>
            <Slider x:Name="KSlider" Minimum="2" Maximum="10" 
                    Value="{Binding K}" Width="150" Margin="5,0" 
                    TickPlacement="BottomRight" TickFrequency="1" 
                    IsSnapToTickEnabled="True"/>
            <TextBlock Text="{Binding K}" Width="30" VerticalAlignment="Center"/>
            <Button Content="Выполнить кластеризацию" 
                    Command="{Binding ClusterCommand}" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>