<Window x:Class="WindowAppearance.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WindowAppearance"
        Title="Curse" Height="600" Width="800"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Кнопка загрузки -->
        <Button Grid.Row="0" 
                Content="Загрузить изображение" 
                Command="{Binding LoadImageCommand}"
                Padding="10" 
                Margin="0,0,0,10"
                HorizontalAlignment="Center"/>

        <!-- Область для изображения -->
        <Border Grid.Row="1" 
                BorderBrush="Gray" 
                BorderThickness="1" 
                Background="LightGray"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Image Source="{Binding LoadedImage}" 
                   Stretch="Uniform" 
                   Margin="5"/>
        </Border>

        <!-- Информационная панель -->
        <TextBlock Grid.Row="2" 
                   Text="{Binding InfoText}" 
                   Margin="0,10,0,0"
                   HorizontalAlignment="Center"
                   FontSize="14"
                   TextWrapping="Wrap"/>
    </Grid>
</Window>