<Window x:Class="GmmImageSegmentator.LoadSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Параметры загрузки изображения"
        Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<Grid Grid.Row="0" Margin="0,0,0,10">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			<TextBox x:Name="FilePathTextBox" Grid.Column="0" IsReadOnly="True"
                     VerticalContentAlignment="Center" Margin="0,0,5,0"/>
			<Button x:Name="BrowseButton" Grid.Column="1" Content="Обзор..."
                    Width="70" Click="BrowseButton_Click"/>
		</Grid>

		<GroupBox Header="Исходное изображение" Grid.Row="1" Margin="0,0,0,10">
			<StackPanel Margin="5">
				<TextBlock x:Name="OriginalSizeText" Text="Файл не выбран"/>
			</StackPanel>
		</GroupBox>

		<GroupBox Header="Настройки масштабирования" Grid.Row="2" Margin="0,0,0,10">
			<StackPanel Margin="5">
				<TextBlock Text="Коэффициент масштаба:"/>
				<Slider x:Name="ScaleSlider" Minimum="0.1" Maximum="1.0"
                        Value="0.5" TickFrequency="0.05" IsSnapToTickEnabled="True"
                        Margin="0,5" ValueChanged="ScaleSlider_ValueChanged"/>
				<TextBlock x:Name="ScaleValueText" Text="50%"/>
			</StackPanel>
		</GroupBox>

		<GroupBox Header="Результат масштабирования" Grid.Row="3" Margin="0,0,0,10">
			<StackPanel Margin="5">
				<TextBlock x:Name="ScaledSizeText" Text="—"/>
				<TextBlock x:Name="ScaledPixelsText" Text="—"/>
			</StackPanel>
		</GroupBox>

		<StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
			<Button Content="ОК" Width="80" IsDefault="True" Click="OkButton_Click" Margin="0,0,5,0"/>
			<Button Content="Отмена" Width="80" IsCancel="True" Click="CancelButton_Click"/>
		</StackPanel>
	</Grid>
</Window>