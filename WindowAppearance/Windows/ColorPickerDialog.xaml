<Window x:Class="GmmImageSegmentator.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор цвета" Height="322" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="None">
    <StackPanel Margin="10">
        <TextBlock Text="R:"/>
        <Slider x:Name="RSlider" Minimum="0" Maximum="255" Value="0"/>
        <TextBox Text="{Binding Value, ElementName=RSlider, StringFormat=F0}" Width="50"/>

        <TextBlock Text="G:" Margin="0,10,0,0"/>
        <Slider x:Name="GSlider" Minimum="0" Maximum="255" Value="0"/>
        <TextBox Text="{Binding Value, ElementName=GSlider, StringFormat=F0}" Width="50"/>

        <TextBlock Text="B:" Margin="0,10,0,0"/>
        <Slider x:Name="BSlider" Minimum="0" Maximum="255" Value="0"/>
        <TextBox Text="{Binding Value, ElementName=BSlider, StringFormat=F0}" Width="50"/>

        <Rectangle x:Name="ColorPreview" Height="18" Margin="0,20" Stroke="Black" StrokeThickness="1"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="ОК" Click="Ok_Click" Width="80" Margin="0,0,10,0" IsDefault="True"/>
            <Button Content="Отмена" Click="Cancel_Click" Width="80" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>