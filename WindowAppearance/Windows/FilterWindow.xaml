<Window x:Class="GmmImageSegmentator.FilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Фильтры сегментации" Height="550" Width="850"
        WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow" 
        Background="{DynamicResource BackgroundBrush}" 
        Foreground="{DynamicResource ForegroundBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="31*"/>
            <RowDefinition Height="226*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10.8"/>
            <ColumnDefinition Width="219.2"/>
            <ColumnDefinition Width="39*"/>
            <ColumnDefinition Width="61*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Width="220" Margin="0,0,10,0" Grid.RowSpan="2" Grid.ColumnSpan="2">
            <TextBlock Text="Доступные фильтры" FontWeight="Bold"/>

            <ListBox x:Name="FiltersListBox" DisplayMemberPath="Name" SelectionChanged="FiltersListBox_SelectionChanged" Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}"/>
            <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto" Margin="0,5,0,0">
                <StackPanel x:Name="FilterSettingsPanel" Margin="0,10,0,0"/>
            </ScrollViewer>
            <Button x:Name="ApplyButton" Content="Применить" Click="ApplyFilter_Click" Margin="0,10,0,0"/>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <Button x:Name="UndoButton" Content="Отменить" Click="Undo_Click" Width="105" Margin="0,0,5,0"/>
                <Button x:Name="RedoButton" Content="Повторить" Click="Redo_Click" Width="109"/>
            </StackPanel>
            <Button Content="Сохранить результат" Click="SaveResult_Click" Margin="0,10,0,0"/>
        </StackPanel>
        <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Grid.RowSpan="2" Grid.ColumnSpan="2">
            <Grid>
                <TextBlock Text="Результат фильтра" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="5"/>
                <Image x:Name="FilteredImage" Stretch="Uniform" Margin="5"/>
            </Grid>
        </Border>
    </Grid>
</Window>