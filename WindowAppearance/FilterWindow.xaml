<Window x:Class="GmmImageSegmentator.FilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Фильтры сегментации" Height="550" Width="850"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Width="220" Margin="0,0,10,0">
            <TextBlock Text="Доступные фильтры" FontWeight="Bold"/>
            <ListBox x:Name="FiltersListBox" DisplayMemberPath="Name" SelectionChanged="FiltersListBox_SelectionChanged"/>
            <StackPanel x:Name="FilterSettingsPanel" Margin="0,10,0,0"/>
            <Button Content="Применить" Click="ApplyFilter_Click" Margin="0,10,0,0"/>
            <Button Content="Сохранить результат" Click="SaveResult_Click" Margin="0,5,0,0"/>
            <Button Content="Закрыть" Click="Close_Click" Margin="0,5,0,0"/>
        </StackPanel>
        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1">
            <Grid>
                <TextBlock Text="Результат фильтра" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="5"/>
                <Image x:Name="FilteredImage" Stretch="Uniform" Margin="5"/>
            </Grid>
        </Border>
    </Grid>
</Window>